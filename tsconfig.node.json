{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.ts", "src/deployment/**/*.ts", "src/deployment/**/*.d.ts", "src/deployment/**/*.d.mts"]
}

# Copy to `.env.local` (gitignored) for local overrides.

# --- Vite / browser (this file) ---
# Local dev: leave VITE_MULTIPLAYER_HOST unset so traffic stays same-origin and Vite proxies
# `/api/multiplayer/*` → Go (:5000). Use `npm run dev:fullstack` or two terminals (mp + web).
#
# Multiplayer Go server (host[:port] only, no path or scheme). When set, the game client
# uses ONLY this host for join, leave, PATCH, health, and SSE — overrides CONFIG.MULTIPLAYER.
# Examples:
#   VITE_MULTIPLAYER_HOST=localhost:5000
#   VITE_MULTIPLAYER_HOST=my-mp.onrender.com
#   VITE_MULTIPLAYER_HOST=https://my-mp.onrender.com   (scheme is stripped automatically)
# VITE_MULTIPLAYER_HOST=

# --- Go multiplayer process (set in Render/Fly/shell, not in Vite) ---
# PORT=5000
# MULTIPLAYER_CORS_ALLOW_ORIGIN=https://your-static-game.example   (optional; defaults to echo Origin or *)
